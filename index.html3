<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HSE Pro Max - Safety Manager</title>
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Chart.js for data visualization -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    animation: {
                        fadeIn: 'fadeIn 0.3s ease-out forwards',
                        ping: 'ping 1.5s cubic-bezier(0, 0, 0.2, 1) infinite'
                    },
                    keyframes: {
                        fadeIn: {
                            '0%': { opacity: '0', transform: 'translateY(10px)' },
                            '100%': { opacity: '1', transform: 'translateY(0)' }
                        }
                    }
                }
            }
        }
    </script>
    <style>
        /* Custom Tooltip using pure CSS */
        .guidance-tooltip-container { position: relative; display: inline-flex; align-items: center; margin-left: 0.5rem; }
        .guidance-tooltip-content {
            display: none; position: absolute; left: 100%; margin-left: 0.5rem; width: 18rem; padding: 1rem;
            background-color: #0f172a; color: white; font-size: 0.875rem; border-radius: 0.75rem;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25); z-index: 50; border: 1px solid #334155;
        }
        .guidance-tooltip-container:hover .guidance-tooltip-content { display: block; animation: fadeIn 0.2s ease-out; }
        
        /* Hide scrollbar for cleaner look */
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 3px; }
        ::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
    </style>
</head>
<body class="flex h-screen bg-slate-50 font-sans text-slate-900 overflow-hidden selection:bg-indigo-200">

    <!-- Sidebar -->
    <aside class="w-72 bg-gradient-to-b from-slate-900 to-slate-950 text-white flex flex-col transition-all duration-300 z-20 shadow-2xl border-r border-slate-800">
        <div class="p-6 flex items-center gap-3 border-b border-slate-800 bg-slate-900/50">
            <div class="p-2 bg-gradient-to-br from-indigo-500 to-purple-600 rounded-lg shadow-lg">
                <i data-lucide="shield-check" class="text-white w-7 h-7"></i>
            </div>
            <div>
                <h1 class="font-extrabold text-xl tracking-tight bg-clip-text text-transparent bg-gradient-to-r from-white to-slate-400">HSE Pro <span class="text-indigo-400">Max</span></h1>
                <p class="text-[10px] text-slate-400 uppercase tracking-widest font-semibold mt-0.5">Safety Operating System</p>
            </div>
        </div>

        <nav class="flex-1 py-6 px-3 space-y-1" id="nav-menu">
            <button onclick="switchTab('dashboard')" class="nav-btn w-full flex items-center gap-3 px-4 py-3 text-sm font-medium rounded-xl transition-all duration-200 group bg-indigo-600/10 text-indigo-400" data-target="dashboard">
                <i data-lucide="home" class="w-5 h-5 text-indigo-400 transition-colors"></i> Command Center
            </button>
            <button onclick="switchTab('jsa')" class="nav-btn w-full flex items-center gap-3 px-4 py-3 text-sm font-medium rounded-xl transition-all duration-200 group text-slate-400 hover:bg-slate-800/50 hover:text-slate-200" data-target="jsa">
                <i data-lucide="layers" class="w-5 h-5 text-slate-500 group-hover:text-slate-300 transition-colors"></i> Risk Assessment (JSA)
            </button>
            <button onclick="switchTab('ptw')" class="nav-btn w-full flex items-center gap-3 px-4 py-3 text-sm font-medium rounded-xl transition-all duration-200 group text-slate-400 hover:bg-slate-800/50 hover:text-slate-200" data-target="ptw">
                <i data-lucide="file-signature" class="w-5 h-5 text-slate-500 group-hover:text-slate-300 transition-colors"></i> Permit to Work (PTW)
            </button>
            <button onclick="switchTab('audits')" class="nav-btn w-full flex items-center gap-3 px-4 py-3 text-sm font-medium rounded-xl transition-all duration-200 group text-slate-400 hover:bg-slate-800/50 hover:text-slate-200" data-target="audits">
                <i data-lucide="clipboard-list" class="w-5 h-5 text-slate-500 group-hover:text-slate-300 transition-colors"></i> Audits & Inspections
            </button>
            <button onclick="switchTab('incidents')" class="nav-btn w-full flex items-center gap-3 px-4 py-3 text-sm font-medium rounded-xl transition-all duration-200 group text-slate-400 hover:bg-slate-800/50 hover:text-slate-200" data-target="incidents">
                <i data-lucide="alert-triangle" class="w-5 h-5 text-slate-500 group-hover:text-slate-300 transition-colors"></i> Incident Management
            </button>
            
            <div class="pt-6 pb-2 px-4">
                <p class="text-xs font-bold text-slate-500 uppercase tracking-wider">Resources</p>
            </div>
            <button onclick="switchTab('guidance')" class="nav-btn w-full flex items-center gap-3 px-4 py-3 text-sm font-medium rounded-xl transition-all duration-200 group text-slate-400 hover:bg-slate-800/50 hover:text-slate-200" data-target="guidance">
                <i data-lucide="book-open" class="w-5 h-5 text-slate-500 group-hover:text-slate-300 transition-colors"></i> Master Guidance
            </button>
        </nav>

        <div class="p-5 border-t border-slate-800 bg-slate-900/50">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-full bg-gradient-to-br from-indigo-500 to-blue-600 flex items-center justify-center font-bold shadow-inner ring-2 ring-slate-800">SP</div>
                <div>
                    <p class="font-semibold text-sm">Safety Professional</p>
                    <p class="text-xs text-indigo-400 font-medium">Regional HSE Director</p>
                </div>
            </div>
        </div>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 flex flex-col h-screen overflow-hidden relative bg-slate-50/50">
        <header class="bg-white/80 backdrop-blur-md h-16 border-b border-slate-200 flex items-center justify-between px-8 shadow-sm z-10 sticky top-0">
            <h2 id="header-title" class="text-xl font-bold text-slate-800 capitalize flex items-center gap-3">
                Command Center
                <div class="guidance-tooltip-container">
                    <i data-lucide="info" class="text-indigo-400 w-4 h-4 cursor-help hover:text-indigo-600 transition-colors"></i>
                    <div class="guidance-tooltip-content">
                        <strong class="block text-indigo-300 mb-2 flex items-center gap-2 border-b border-slate-700 pb-2">
                            <i data-lucide="shield-check" class="w-4 h-4"></i> Module Info
                        </strong>
                        <p class="leading-relaxed text-slate-200">Ensure all data entered is accurate and objective. This system serves as a legal record of safety compliance and due diligence.</p>
                    </div>
                </div>
            </h2>
            <div class="flex items-center gap-6">
                <div class="hidden md:flex items-center gap-2 text-sm font-semibold text-emerald-700 bg-emerald-50 px-4 py-1.5 rounded-full border border-emerald-200 shadow-sm">
                    <span class="relative flex h-3 w-3">
                        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                        <span class="relative inline-flex rounded-full h-3 w-3 bg-emerald-500"></span>
                    </span>
                    Site Status: Operational
                </div>
            </div>
        </header>

        <div class="flex-1 overflow-y-auto p-8 relative">
            <div class="max-w-7xl mx-auto">
                
                <!-- VIEWS -->
                
                <!-- Dashboard View -->
                <div id="view-dashboard" class="view-section animate-fadeIn block space-y-8">
                    <div class="flex justify-between items-end">
                        <div>
                            <h3 class="text-3xl font-extrabold text-slate-800 tracking-tight">Command Center</h3>
                            <p class="text-slate-500 font-medium mt-1">Real-time enterprise safety intelligence.</p>
                        </div>
                    </div>
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                        <div class="bg-white p-6 rounded-2xl shadow-sm border-t-4 border-indigo-500 hover:shadow-md transition-all group">
                            <div class="flex justify-between items-start">
                                <div>
                                    <p class="text-slate-500 text-sm font-semibold tracking-wide uppercase">TRIR (YTD)</p>
                                    <h3 class="text-4xl font-extrabold text-slate-800 mt-2 mb-1 group-hover:scale-105 transition-transform origin-left">1.1</h3>
                                </div>
                                <div class="p-3 rounded-xl bg-slate-50 group-hover:bg-slate-100 transition-colors"><i data-lucide="crosshair" class="text-indigo-500 w-6 h-6"></i></div>
                            </div>
                            <div class="flex items-center gap-2 mt-3">
                                <span class="text-xs font-bold px-2 py-0.5 rounded-full bg-emerald-100 text-emerald-700">-0.2</span>
                                <p class="text-xs text-slate-400 font-medium">Industry Avg: 2.4</p>
                            </div>
                        </div>
                        <div class="bg-white p-6 rounded-2xl shadow-sm border-t-4 border-emerald-500 hover:shadow-md transition-all group">
                            <div class="flex justify-between items-start">
                                <div>
                                    <p class="text-slate-500 text-sm font-semibold tracking-wide uppercase">Days Without LTI</p>
                                    <h3 class="text-4xl font-extrabold text-slate-800 mt-2 mb-1 group-hover:scale-105 transition-transform origin-left">142</h3>
                                </div>
                                <div class="p-3 rounded-xl bg-slate-50 group-hover:bg-slate-100 transition-colors"><i data-lucide="shield-check" class="text-emerald-500 w-6 h-6"></i></div>
                            </div>
                            <div class="flex items-center gap-2 mt-3">
                                <p class="text-xs text-slate-400 font-medium">Goal: 365 Days</p>
                            </div>
                        </div>
                        <div class="bg-white p-6 rounded-2xl shadow-sm border-t-4 border-amber-500 hover:shadow-md transition-all group">
                            <div class="flex justify-between items-start">
                                <div>
                                    <p class="text-slate-500 text-sm font-semibold tracking-wide uppercase">High Risk Permits</p>
                                    <h3 id="dash-permit-count" class="text-4xl font-extrabold text-slate-800 mt-2 mb-1 group-hover:scale-105 transition-transform origin-left">0</h3>
                                </div>
                                <div class="p-3 rounded-xl bg-slate-50 group-hover:bg-slate-100 transition-colors"><i data-lucide="file-signature" class="text-amber-500 w-6 h-6"></i></div>
                            </div>
                            <div class="flex items-center gap-2 mt-3">
                                <p class="text-xs text-slate-400 font-medium">Active Hot Work/Confined</p>
                            </div>
                        </div>
                        <div class="bg-white p-6 rounded-2xl shadow-sm border-t-4 border-red-500 hover:shadow-md transition-all group">
                            <div class="flex justify-between items-start">
                                <div>
                                    <p class="text-slate-500 text-sm font-semibold tracking-wide uppercase">Open Corrective Actions</p>
                                    <h3 class="text-4xl font-extrabold text-slate-800 mt-2 mb-1 group-hover:scale-105 transition-transform origin-left">12</h3>
                                </div>
                                <div class="p-3 rounded-xl bg-slate-50 group-hover:bg-slate-100 transition-colors"><i data-lucide="alert-circle" class="text-red-500 w-6 h-6"></i></div>
                            </div>
                            <div class="flex items-center gap-2 mt-3">
                                <p class="text-xs text-slate-400 font-medium">3 Critical Overdue</p>
                            </div>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                        <div class="lg:col-span-2 bg-white p-6 rounded-2xl shadow-sm border border-slate-200">
                            <div class="flex items-center justify-between mb-6">
                                <h4 class="text-lg font-bold text-slate-800">Incident & TRIR Trends</h4>
                            </div>
                            <div class="h-80 relative">
                                <canvas id="trendChart"></canvas>
                            </div>
                        </div>

                        <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-200 flex flex-col">
                            <div class="flex items-center justify-between mb-2">
                                <h4 class="text-lg font-bold text-slate-800">Audit Compliance</h4>
                            </div>
                            <p class="text-3xl font-extrabold text-emerald-600 mb-6 text-center">88% <span class="text-sm text-slate-500 font-medium">Pass Rate</span></p>
                            <div class="flex-1 min-h-[200px] relative flex justify-center">
                                <canvas id="complianceChart"></canvas>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- JSA View -->
                <div id="view-jsa" class="view-section animate-fadeIn hidden">
                    <div id="jsa-list-view">
                        <div class="flex justify-between items-center mb-8">
                            <div>
                                <h3 class="text-3xl font-extrabold text-slate-800 tracking-tight">Job Safety Analysis (JSA)</h3>
                                <p class="text-slate-500 font-medium mt-1">Identify hazards and establish controls before work begins.</p>
                            </div>
                            <button onclick="toggleForm('jsa', true)" class="bg-indigo-600 hover:bg-indigo-700 text-white px-5 py-2.5 rounded-xl shadow-lg shadow-indigo-200 flex items-center gap-2 font-semibold transition-all hover:-translate-y-0.5">
                                <i data-lucide="plus" class="w-5 h-5"></i> Create JSA
                            </button>
                        </div>
                        <div id="jsa-container" class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <!-- JSAs populated here -->
                        </div>
                    </div>
                    
                    <div id="jsa-form-view" class="hidden bg-white p-8 rounded-2xl shadow-lg border border-slate-200 max-w-3xl mx-auto">
                        <div class="flex justify-between items-center mb-6 border-b border-slate-100 pb-4">
                            <h3 class="text-2xl font-bold text-slate-800 flex items-center gap-2">
                                <i data-lucide="layers" class="text-indigo-600"></i> New Job Safety Analysis
                            </h3>
                            <button onclick="toggleForm('jsa', false)" class="text-slate-400 hover:text-slate-600 bg-slate-100 p-2 rounded-full transition-colors"><i data-lucide="x-circle" class="w-5 h-5"></i></button>
                        </div>
                        <form id="jsaForm" class="space-y-6">
                            <div class="grid grid-cols-2 gap-6">
                                <div class="mb-5">
                                    <label class="block text-sm font-semibold text-slate-700 mb-1.5">Task Description</label>
                                    <input required name="taskName" type="text" class="w-full p-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 outline-none transition-all" placeholder="Enter task name" />
                                </div>
                                <div class="mb-5">
                                    <label class="block text-sm font-semibold text-slate-700 mb-1.5">Location</label>
                                    <input required name="location" type="text" class="w-full p-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 outline-none transition-all" placeholder="Enter location" />
                                </div>
                            </div>
                            <div class="mb-5">
                                <label class="block text-sm font-semibold text-slate-700 mb-1.5">Potential Hazards</label>
                                <textarea required name="hazards" rows="3" class="w-full p-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 outline-none transition-all" placeholder="List identified hazards..."></textarea>
                            </div>
                            <div class="mb-5">
                                <label class="block text-sm font-semibold text-slate-700 mb-1.5">Risk Controls (Hierarchy of Controls)</label>
                                <textarea required name="controls" rows="4" class="w-full p-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 outline-none transition-all font-mono text-sm" placeholder="- Control 1&#10;- Control 2"></textarea>
                            </div>
                            <div class="mb-5">
                                <label class="block text-sm font-semibold text-slate-700 mb-1.5">Residual Risk</label>
                                <select name="residualRisk" class="w-full p-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-indigo-500 outline-none transition-all">
                                    <option value="Low">Low (Acceptable)</option>
                                    <option value="Medium">Medium (ALARP - Needs Mgmt Approval)</option>
                                    <option value="High">High (Unacceptable - Stop Work)</option>
                                </select>
                            </div>
                            <div class="flex justify-end gap-4 pt-6 border-t border-slate-100">
                                <button type="button" onclick="toggleForm('jsa', false)" class="px-6 py-2.5 text-slate-600 font-semibold hover:bg-slate-100 rounded-xl transition-colors">Cancel</button>
                                <button type="submit" class="px-6 py-2.5 bg-indigo-600 text-white font-semibold rounded-xl hover:bg-indigo-700 shadow-md shadow-indigo-200 transition-all flex items-center gap-2">
                                    Approve JSA <i data-lucide="check-circle" class="w-4 h-4"></i>
                                </button>
                            </div>
                        </form>
                    </div>
                </div>

                <!-- Audits View -->
                <div id="view-audits" class="view-section animate-fadeIn hidden">
                    <div id="audits-list-view">
                        <div class="flex justify-between items-center mb-8">
                            <div>
                                <h3 class="text-3xl font-extrabold text-slate-800 tracking-tight">Audit & Inspections</h3>
                                <p class="text-slate-500 font-medium mt-1">Proactive hazard identification and compliance tracking.</p>
                            </div>
                            <button onclick="toggleForm('audits', true)" class="bg-blue-600 hover:bg-blue-700 text-white px-5 py-2.5 rounded-xl shadow-lg shadow-blue-200 flex items-center gap-2 font-semibold transition-all hover:-translate-y-0.5">
                                <i data-lucide="plus" class="w-5 h-5"></i> New Audit
                            </button>
                        </div>
                        <div id="audits-container">
                            <!-- Audits populated here -->
                        </div>
                    </div>

                    <div id="audits-form-view" class="hidden bg-white p-8 rounded-2xl shadow-lg border border-slate-200">
                        <div class="flex justify-between items-center mb-8 border-b border-slate-100 pb-4">
                            <h3 class="text-2xl font-bold text-slate-800 flex items-center gap-2">Conduct Formal Audit</h3>
                            <button onclick="toggleForm('audits', false)" class="text-slate-400 hover:text-slate-600 bg-slate-100 p-2 rounded-full transition-colors"><i data-lucide="x-circle" class="w-5 h-5"></i></button>
                        </div>
                        <form id="auditForm">
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8">
                                <div class="mb-5">
                                    <label class="block text-sm font-semibold text-slate-700 mb-1.5">Audit Standard / Domain</label>
                                    <select id="auditType" name="type" class="w-full p-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none font-medium text-slate-700 bg-slate-50" onchange="renderChecklist()">
                                        <option value="General Site Safety">General Site Safety</option>
                                        <option value="Work at Height">Work at Height</option>
                                        <option value="Fire Safety & Hot Work">Fire Safety & Hot Work</option>
                                    </select>
                                </div>
                                <div class="mb-5">
                                    <label class="block text-sm font-semibold text-slate-700 mb-1.5">Specific Location / Zone</label>
                                    <input required name="location" type="text" placeholder="e.g. Scaffold Block B" class="w-full p-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-blue-500 outline-none" />
                                </div>
                            </div>
                            <div class="mb-8">
                                <div class="flex items-center justify-between mb-4">
                                    <h4 class="font-bold text-lg text-slate-800">Expert Verification Checklist</h4>
                                </div>
                                <div id="checklist-container" class="space-y-4">
                                    <!-- Dynamic Checklist items -->
                                </div>
                            </div>
                            <div class="flex justify-end gap-4 pt-6 border-t border-slate-100">
                                <button type="button" onclick="toggleForm('audits', false)" class="px-6 py-2.5 text-slate-600 font-semibold hover:bg-slate-100 rounded-xl transition-colors">Cancel</button>
                                <button type="submit" class="px-6 py-2.5 bg-blue-600 text-white font-semibold rounded-xl hover:bg-blue-700 shadow-md shadow-blue-200 transition-all flex items-center gap-2">
                                    Submit Audit <i data-lucide="check-circle" class="w-4 h-4"></i>
                                </button>
                            </div>
                        </form>
                    </div>
                </div>

                <!-- Incidents View -->
                <div id="view-incidents" class="view-section animate-fadeIn hidden">
                    <div id="incidents-list-view">
                        <div class="flex justify-between items-center mb-8">
                            <div>
                                <h3 class="text-3xl font-extrabold text-slate-800 tracking-tight">Incident Management</h3>
                                <p class="text-slate-500 font-medium mt-1">Capture, analyze root causes, and establish preventive measures.</p>
                            </div>
                            <button onclick="toggleForm('incidents', true)" class="bg-red-600 hover:bg-red-700 text-white px-5 py-2.5 rounded-xl shadow-lg shadow-red-200 flex items-center gap-2 font-semibold transition-all hover:-translate-y-0.5">
                                <i data-lucide="alert-triangle" class="w-5 h-5"></i> Report Incident
                            </button>
                        </div>
                        <div id="incidents-container" class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <!-- Incidents populated here -->
                        </div>
                    </div>

                    <div id="incidents-form-view" class="hidden bg-white p-8 rounded-2xl shadow-lg border border-slate-200 max-w-4xl mx-auto">
                        <div class="flex justify-between items-center mb-8 border-b border-slate-100 pb-4">
                            <h3 class="text-2xl font-bold text-slate-800 flex items-center gap-2">
                                <i data-lucide="alert-triangle" class="text-red-500"></i> Report New Incident
                            </h3>
                            <button onclick="toggleForm('incidents', false)" class="text-slate-400 hover:text-slate-600 bg-slate-100 p-2 rounded-full transition-colors"><i data-lucide="x-circle" class="w-5 h-5"></i></button>
                        </div>
                        <form id="incidentForm" class="space-y-6">
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div class="mb-5">
                                    <label class="block text-sm font-semibold text-slate-700 mb-1.5">Incident Title</label>
                                    <input required name="title" class="w-full p-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-red-500 outline-none transition-all font-semibold text-slate-800" placeholder="Brief title" />
                                </div>
                                <div class="mb-5">
                                    <label class="block text-sm font-semibold text-slate-700 mb-1.5">Severity Category</label>
                                    <select id="incidentCategory" name="category" class="w-full p-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-red-500 outline-none transition-all font-semibold bg-slate-50 text-slate-700" onchange="toggleRootCause()">
                                        <option value="Near Miss">Near Miss</option>
                                        <option value="First Aid Case">First Aid Case</option>
                                        <option value="Medical Treatment Case">Medical Treatment Case</option>
                                        <option value="Lost Time Incident (LTI)">Lost Time Incident (LTI)</option>
                                    </select>
                                </div>
                            </div>
                            <div class="mb-5">
                                <label class="block text-sm font-semibold text-slate-700 mb-1.5">Exact Location</label>
                                <input required name="location" class="w-full p-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-red-500 outline-none transition-all" placeholder="e.g., Warehouse Loading Bay 2" />
                            </div>
                            <div class="mb-5">
                                <label class="block text-sm font-semibold text-slate-700 mb-1.5">Detailed Factual Description</label>
                                <textarea required name="description" rows="3" class="w-full p-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-red-500 outline-none transition-all" placeholder="Describe the sequence of events objectively..."></textarea>
                            </div>
                            <div class="mb-5">
                                <label class="block text-sm font-semibold text-slate-700 mb-1.5">Immediate Corrective Action</label>
                                <textarea required name="action" rows="2" class="w-full p-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-red-500 outline-none transition-all" placeholder="Steps taken to secure the scene..."></textarea>
                            </div>
                            
                            <div id="rootCauseSection" class="hidden bg-red-50 p-6 rounded-2xl border border-red-200 mt-8">
                                <h4 class="text-red-800 font-bold flex items-center gap-2 mb-2">
                                    <i data-lucide="file-search" class="w-4 h-4"></i> Root Cause Analysis (Mandatory for LTI/MTC)
                                </h4>
                                <p class="text-sm text-red-600 mb-4">You have selected a high-severity category. Please provide preliminary root cause findings using the '5 Whys' methodology.</p>
                                <div class="mb-5">
                                    <label class="block text-sm font-semibold text-slate-700 mb-1.5">Identified Root Cause</label>
                                    <textarea name="rootCause" rows="3" class="w-full p-3 border border-red-300 rounded-xl focus:ring-2 focus:ring-red-500 outline-none transition-all" placeholder="State the fundamental system or process failure..."></textarea>
                                </div>
                            </div>
                            
                            <div class="flex justify-end gap-4 pt-6 border-t border-slate-100">
                                <button type="button" onclick="toggleForm('incidents', false)" class="px-6 py-2.5 text-slate-600 font-semibold hover:bg-slate-100 rounded-xl transition-colors">Cancel</button>
                                <button type="submit" class="px-6 py-2.5 bg-red-600 text-white font-semibold rounded-xl hover:bg-red-700 shadow-md shadow-red-200 transition-all flex items-center gap-2">
                                    Submit Official Report <i data-lucide="send" class="w-4 h-4"></i>
                                </button>
                            </div>
                        </form>
                    </div>
                </div>

                <!-- PTW View -->
                <div id="view-ptw" class="view-section animate-fadeIn hidden">
                    <div id="ptw-list-view">
                        <div class="flex justify-between items-center mb-8">
                            <div>
                                <h3 class="text-3xl font-extrabold text-slate-800 tracking-tight">Permit to Work (PTW)</h3>
                                <p class="text-slate-500 font-medium mt-1">Strict control system for high-risk, non-routine activities.</p>
                            </div>
                            <button onclick="toggleForm('ptw', true)" class="bg-amber-500 hover:bg-amber-600 text-white px-5 py-2.5 rounded-xl shadow-lg shadow-amber-200 flex items-center gap-2 font-semibold transition-all hover:-translate-y-0.5">
                                <i data-lucide="file-signature" class="w-5 h-5"></i> Authorize Permit
                            </button>
                        </div>
                        <div id="ptw-container" class="grid grid-cols-1 xl:grid-cols-2 gap-6">
                            <!-- Permits populated here -->
                        </div>
                    </div>

                    <div id="ptw-form-view" class="hidden bg-white p-8 rounded-2xl shadow-lg border border-slate-200 max-w-3xl mx-auto">
                        <div class="flex justify-between items-center mb-8 border-b border-slate-100 pb-4">
                            <h3 class="text-2xl font-bold text-slate-800 flex items-center gap-2">
                                <i data-lucide="file-signature" class="text-amber-500"></i> Authorize New Permit
                            </h3>
                            <button onclick="toggleForm('ptw', false)" class="text-slate-400 hover:text-slate-600 bg-slate-100 p-2 rounded-full transition-colors"><i data-lucide="x-circle" class="w-5 h-5"></i></button>
                        </div>
                        <form id="ptwForm" class="space-y-6">
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div class="mb-5">
                                    <label class="block text-sm font-semibold text-slate-700 mb-1.5">Permit Type</label>
                                    <select name="type" class="w-full p-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-amber-500 outline-none font-semibold bg-slate-50">
                                        <option>Hot Work (Welding, Grinding)</option>
                                        <option>Confined Space Entry</option>
                                        <option>Working at Height (>1.8m)</option>
                                        <option>Critical Lifting Operation</option>
                                        <option>LOTO (Lockout/Tagout)</option>
                                    </select>
                                </div>
                                <div class="mb-5">
                                    <label class="block text-sm font-semibold text-slate-700 mb-1.5">Specific Task Scope</label>
                                    <input required name="task" class="w-full p-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-amber-500 outline-none" placeholder="e.g., Welding pipe joint section 4" />
                                </div>
                            </div>
                            <div class="mb-5">
                                <label class="block text-sm font-semibold text-slate-700 mb-1.5">Exact Location</label>
                                <input required name="location" class="w-full p-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-amber-500 outline-none" placeholder="e.g., Basement Level 2, Pump Room" />
                            </div>
                            
                            <div class="bg-amber-50 p-5 rounded-2xl border border-amber-200 mt-8">
                                <div class="flex items-center gap-2 text-amber-800 font-extrabold mb-3 text-lg">
                                    <i data-lucide="alert-triangle" class="w-5 h-5"></i> Legal Acknowledgment
                                </div>
                                <p class="text-sm text-amber-700 leading-relaxed font-medium">By issuing this permit, I confirm that a Job Safety Analysis (JSA) has been conducted, hazards identified, controls are currently in place at the physical worksite, and all involved personnel have been briefed.</p>
                                <div class="mt-4 flex items-center gap-3">
                                    <input type="checkbox" required class="w-5 h-5 text-amber-600 rounded border-gray-300 focus:ring-amber-500" />
                                    <span class="text-sm font-bold text-amber-900">I verify site conditions personally.</span>
                                </div>
                            </div>

                            <div class="flex justify-end gap-4 pt-6 border-t border-slate-100">
                                <button type="button" onclick="toggleForm('ptw', false)" class="px-6 py-2.5 text-slate-600 font-semibold hover:bg-slate-100 rounded-xl transition-colors">Cancel</button>
                                <button type="submit" class="px-6 py-2.5 bg-amber-500 text-white font-semibold rounded-xl hover:bg-amber-600 shadow-md shadow-amber-200 transition-all flex items-center gap-2">
                                    Authorize & Issue <i data-lucide="check-circle" class="w-4 h-4"></i>
                                </button>
                            </div>
                        </form>
                    </div>
                </div>

                <!-- Guidance View -->
                <div id="view-guidance" class="view-section animate-fadeIn hidden">
                    <div class="max-w-4xl mx-auto space-y-10 pb-12">
                        <div class="text-center space-y-4 py-8 border-b border-slate-200">
                            <div class="inline-flex items-center justify-center w-20 h-20 rounded-2xl bg-gradient-to-br from-indigo-500 to-blue-600 text-white shadow-xl shadow-indigo-200 mb-2">
                                <i data-lucide="book-open" class="w-10 h-10"></i>
                            </div>
                            <h2 class="text-4xl font-extrabold text-slate-800 tracking-tight">Master Safety Guidance</h2>
                            <p class="text-lg text-slate-500 font-medium max-w-2xl mx-auto">The 15-Year Expert's Manual to deploying this Application effectively in Saudi Arabia and International Markets.</p>
                        </div>
                  
                        <div class="bg-white rounded-2xl shadow-lg border border-slate-200 overflow-hidden">
                            <div class="bg-gradient-to-r from-indigo-600 to-blue-600 p-6 text-white">
                                <h3 class="text-2xl font-bold flex items-center gap-3"><i data-lucide="shield-check" class="w-7 h-7"></i> Principle: The Hierarchy of Controls</h3>
                                <p class="text-indigo-100 mt-2 font-medium">The golden rule of risk management. Always apply controls from top to bottom.</p>
                            </div>
                            <div class="p-8">
                                <ul class="space-y-6">
                                    <li class="flex items-start gap-4">
                                        <span class="w-10 h-10 rounded-xl bg-emerald-100 text-emerald-700 flex items-center justify-center font-black text-lg shrink-0">1</span> 
                                        <div>
                                            <strong class="text-lg text-slate-800 block mb-1">Elimination (Most Effective)</strong>
                                            <p class="text-slate-600">Physically remove the hazard completely. Example: Do work at ground level instead of at height.</p>
                                        </div>
                                    </li>
                                    <li class="flex items-start gap-4">
                                        <span class="w-10 h-10 rounded-xl bg-blue-100 text-blue-700 flex items-center justify-center font-black text-lg shrink-0">2</span> 
                                        <div>
                                            <strong class="text-lg text-slate-800 block mb-1">Substitution</strong>
                                            <p class="text-slate-600">Replace the hazard with something safer. Example: Use a non-toxic chemical instead of a toxic one.</p>
                                        </div>
                                    </li>
                                    <li class="flex items-start gap-4">
                                        <span class="w-10 h-10 rounded-xl bg-amber-100 text-amber-700 flex items-center justify-center font-black text-lg shrink-0">3</span> 
                                        <div>
                                            <strong class="text-lg text-slate-800 block mb-1">Engineering Controls</strong>
                                            <p class="text-slate-600">Isolate people from the hazard. Example: Machine guards, sound enclosures, ventilation systems.</p>
                                        </div>
                                    </li>
                                    <li class="flex items-start gap-4">
                                        <span class="w-10 h-10 rounded-xl bg-orange-100 text-orange-700 flex items-center justify-center font-black text-lg shrink-0">4</span> 
                                        <div>
                                            <strong class="text-lg text-slate-800 block mb-1">Administrative Controls</strong>
                                            <p class="text-slate-600">Change the way people work. Example: Training, job rotation, standard operating procedures (SOPs).</p>
                                        </div>
                                    </li>
                                    <li class="flex items-start gap-4">
                                        <span class="w-10 h-10 rounded-xl bg-red-100 text-red-700 flex items-center justify-center font-black text-lg shrink-0">5</span> 
                                        <div>
                                            <strong class="text-lg text-slate-800 block mb-1">PPE (Last Line of Defense)</strong>
                                            <p class="text-slate-600">Protect the worker with equipment. Hard hats, harnesses, respirators. It does not eliminate the hazard!</p>
                                        </div>
                                    </li>
                                </ul>
                            </div>
                        </div>
                  
                        <div class="grid md:grid-cols-2 gap-6">
                            <div class="bg-white p-8 rounded-2xl shadow-sm border border-slate-200 hover:shadow-lg transition-all hover:-translate-y-1">
                                <div class="flex items-center gap-4 mb-4">
                                    <div class="p-3 bg-slate-50 rounded-xl border border-slate-100 shadow-inner"><i data-lucide="clipboard-list" class="text-blue-500 w-7 h-7"></i></div>
                                    <h4 class="text-xl font-bold text-slate-800">How to Audit Properly</h4>
                                </div>
                                <p class="text-slate-600 leading-relaxed font-medium">An audit is not a policing exercise; it is an objective measurement of compliance against a standard. Engage with workers. Do not conduct 'desk audits' from your office.</p>
                            </div>
                            <div class="bg-white p-8 rounded-2xl shadow-sm border border-slate-200 hover:shadow-lg transition-all hover:-translate-y-1">
                                <div class="flex items-center gap-4 mb-4">
                                    <div class="p-3 bg-slate-50 rounded-xl border border-slate-100 shadow-inner"><i data-lucide="file-signature" class="text-amber-500 w-7 h-7"></i></div>
                                    <h4 class="text-xl font-bold text-slate-800">PTW Golden Rules</h4>
                                </div>
                                <p class="text-slate-600 leading-relaxed font-medium">A Permit to Work is void if conditions change. If a fire alarm sounds, the Hot Work permit is instantly cancelled and must be re-issued. Inspect the physical location first.</p>
                            </div>
                            <div class="bg-white p-8 rounded-2xl shadow-sm border border-slate-200 hover:shadow-lg transition-all hover:-translate-y-1">
                                <div class="flex items-center gap-4 mb-4">
                                    <div class="p-3 bg-slate-50 rounded-xl border border-slate-100 shadow-inner"><i data-lucide="layers" class="text-purple-500 w-7 h-7"></i></div>
                                    <h4 class="text-xl font-bold text-slate-800">Effective JSAs</h4>
                                </div>
                                <p class="text-slate-600 leading-relaxed font-medium">A generic JSA is useless. Break down the specific task step-by-step. Involve the workers who will actually do the job in writing the JSA. They know the hidden hazards best.</p>
                            </div>
                            <div class="bg-white p-8 rounded-2xl shadow-sm border border-slate-200 hover:shadow-lg transition-all hover:-translate-y-1">
                                <div class="flex items-center gap-4 mb-4">
                                    <div class="p-3 bg-slate-50 rounded-xl border border-slate-100 shadow-inner"><i data-lucide="bot" class="text-indigo-500 w-7 h-7"></i></div>
                                    <h4 class="text-xl font-bold text-slate-800">Leveraging AI Chatbot</h4>
                                </div>
                                <p class="text-slate-600 leading-relaxed font-medium">The AI (bottom right) is connected to a Gemini intelligence model. Ask it complex regulatory questions like 'What is the OSHA standard for trench shoring?'</p>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </main>

    <!-- AI Chatbot FAB -->
    <button id="chat-fab" onclick="toggleChat()" class="fixed bottom-8 right-8 w-16 h-16 rounded-full shadow-2xl flex items-center justify-center transition-all duration-300 z-50 hover:scale-110 bg-gradient-to-r from-indigo-600 to-blue-600 text-white shadow-indigo-300/50">
        <i data-lucide="bot" id="chat-icon-bot" class="w-8 h-8"></i>
        <i data-lucide="x-circle" id="chat-icon-close" class="w-8 h-8 hidden"></i>
    </button>

    <!-- AI Chatbot Window -->
    <div id="chat-window" class="hidden fixed bottom-28 right-8 w-[400px] h-[600px] bg-white rounded-2xl shadow-2xl border border-slate-200 flex flex-col z-50 overflow-hidden animate-fadeIn">
        <!-- Header -->
        <div class="bg-gradient-to-r from-indigo-600 to-blue-700 p-5 text-white flex justify-between items-center shadow-md z-10">
            <div class="flex items-center gap-3">
                <div class="p-2 bg-white/20 rounded-lg backdrop-blur-sm">
                    <i data-lucide="bot" class="w-6 h-6"></i>
                </div>
                <div>
                    <h4 class="font-bold text-lg leading-tight">AI Safety Expert</h4>
                    <p class="text-xs text-indigo-200 font-medium flex items-center gap-1">
                        <span class="w-2 h-2 rounded-full bg-emerald-400"></span> Online - Gemini Powered
                    </p>
                </div>
            </div>
        </div>

        <!-- Messages Area -->
        <div id="chat-messages" class="flex-1 p-5 overflow-y-auto bg-slate-50 space-y-5">
            <!-- Messages populated by JS -->
        </div>

        <!-- Typing Indicator -->
        <div id="typing-indicator" class="hidden flex justify-start p-5 pt-0 bg-slate-50">
            <div class="w-8 h-8 rounded-full bg-indigo-100 flex items-center justify-center mr-2 shrink-0"><i data-lucide="bot" class="w-4 h-4 text-indigo-600"></i></div>
            <div class="bg-white border border-slate-200 p-4 rounded-2xl rounded-tl-sm shadow-sm flex items-center gap-2">
                <i data-lucide="loader-2" class="w-4 h-4 text-indigo-500 animate-spin"></i>
                <span class="text-xs text-slate-500 font-medium">Analyzing safety standards...</span>
            </div>
        </div>

        <!-- Input -->
        <form id="chatForm" onsubmit="handleChatSubmit(event)" class="p-4 bg-white border-t border-slate-200">
            <div class="relative flex items-center">
                <input id="chatInput" type="text" placeholder="Ask about regulations, risk, or procedures..." class="w-full pl-4 pr-12 py-3 bg-slate-100 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:bg-white transition-all" />
                <button id="chatSubmitBtn" type="submit" class="absolute right-2 p-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 disabled:opacity-50 disabled:hover:bg-indigo-600 transition-colors shadow-md">
                    <i data-lucide="send" class="w-4 h-4"></i>
                </button>
            </div>
            <p class="text-[10px] text-center text-slate-400 mt-2">AI-generated advice should be verified with local regulations.</p>
        </form>
    </div>

    <!-- Application Script -->
    <script>
        // --- Data Definitions ---
        const DASHBOARD_DATA = {
            incidentTrend: [
                { month: 'Jan', nearMiss: 4, lti: 0, firstAid: 2, trir: 1.2 },
                { month: 'Feb', nearMiss: 3, lti: 1, firstAid: 1, trir: 2.1 },
                { month: 'Mar', nearMiss: 6, lti: 0, firstAid: 3, trir: 1.8 },
                { month: 'Apr', nearMiss: 2, lti: 0, firstAid: 0, trir: 1.5 },
                { month: 'May', nearMiss: 5, lti: 0, firstAid: 2, trir: 1.3 },
                { month: 'Jun', nearMiss: 1, lti: 0, firstAid: 1, trir: 1.1 },
            ],
            auditCompliance: [
                { name: 'Compliant', value: 88, color: '#10b981' },
                { name: 'Minor Non-Conformance', value: 9, color: '#f59e0b' },
                { name: 'Major Non-Conformance', value: 3, color: '#ef4444' },
            ]
        };

        const EXPERT_CHECKLISTS = {
            'General Site Safety': [
                'Are all workers wearing mandatory minimum PPE (Hard hat, safety glasses, steel-toe boots, hi-vis vest)?',
                'Are pedestrian walkways clearly segregated from vehicle traffic with hard barricades?',
                'Is housekeeping maintained to prevent slip, trip, and fall hazards?',
                'Are emergency assembly points clearly marked, accessible, and well-lit?'
            ],
            'Work at Height': [
                'Is scaffolding erected by a competent person and green-tagged (inspected in last 7 days)?',
                'Are full-body harnesses inspected before use and tied off 100% of the time above 1.8m?',
                'Are edge protections (guardrails, mid-rails, toe boards) secure and complete?',
                'Are ladders tied off at the top, placed at a 4:1 angle, and extending 1m above the landing?'
            ],
            'Fire Safety & Hot Work': [
                'Are fire extinguishers inspected monthly, tagged, fully charged, and easily accessible?',
                'Are combustible materials removed at least 11m (35ft) from hot work areas?',
                'Is a dedicated, trained fire watch assigned for the duration of hot work + 30 mins after?',
                'Are gas cylinders stored upright, secured with chains, and segregated (Oxygen vs. Acetylene by 6m or fire wall)?'
            ]
        };

        // --- Application State ---
        let currentTab = 'dashboard';
        let jsas = [];
        let audits = [];
        let incidents = [];
        let permits = [];
        let currentChecklistStatus = [];
        let isChatOpen = false;
        let isTyping = false;
        let chatMessages = [
            { role: 'ai', text: 'Hello! I am your AI HSE Director. Powered by Gemini, I am trained on OSHA, NEBOSH, and global safety standards. How can I assist your operations today?' }
        ];

        // --- Initialization ---
        document.addEventListener("DOMContentLoaded", () => {
            lucide.createIcons();
            initCharts();
            renderJSAs();
            renderAudits();
            renderIncidents();
            renderPermits();
            renderMessages();
            renderChecklist();
        });

        // --- Navigation ---
        function switchTab(tabId) {
            currentTab = tabId;
            
            // Update Header
            const headers = {
                'dashboard': 'Command Center', 'jsa': 'Risk Assessment (JSA)',
                'ptw': 'Permit to Work (PTW)', 'audits': 'Audits & Inspections',
                'incidents': 'Incident Management', 'guidance': 'Master Guidance'
            };
            document.getElementById('header-title').innerHTML = `${headers[tabId]} 
                <div class="guidance-tooltip-container">
                    <i data-lucide="info" class="text-indigo-400 w-4 h-4 cursor-help hover:text-indigo-600 transition-colors"></i>
                    <div class="guidance-tooltip-content">
                        <strong class="block text-indigo-300 mb-2 flex items-center gap-2 border-b border-slate-700 pb-2">
                            <i data-lucide="shield-check" class="w-4 h-4"></i> Module Info
                        </strong>
                        <p class="leading-relaxed text-slate-200">Ensure all data entered is accurate and objective. This system serves as a legal record of safety compliance and due diligence.</p>
                    </div>
                </div>`;
            
            // Toggle visibility of sections
            document.querySelectorAll('.view-section').forEach(el => el.classList.add('hidden'));
            document.getElementById(`view-${tabId}`).classList.remove('hidden');

            // Toggle active state in sidebar
            document.querySelectorAll('.nav-btn').forEach(btn => {
                if(btn.dataset.target === tabId) {
                    btn.className = "nav-btn w-full flex items-center gap-3 px-4 py-3 text-sm font-medium rounded-xl transition-all duration-200 group bg-indigo-600/10 text-indigo-400";
                    btn.querySelector('i').className = "w-5 h-5 text-indigo-400 transition-colors";
                } else {
                    btn.className = "nav-btn w-full flex items-center gap-3 px-4 py-3 text-sm font-medium rounded-xl transition-all duration-200 group text-slate-400 hover:bg-slate-800/50 hover:text-slate-200";
                    btn.querySelector('i').className = "w-5 h-5 text-slate-500 group-hover:text-slate-300 transition-colors";
                }
            });

            // Make sure list views are shown when switching to a tab
            if(['jsa', 'audits', 'incidents', 'ptw'].includes(tabId)) {
                toggleForm(tabId, false);
            }
            
            lucide.createIcons();
        }

        function toggleForm(module, show) {
            const listView = document.getElementById(`${module}-list-view`);
            const formView = document.getElementById(`${module}-form-view`);
            if(show) {
                listView.classList.add('hidden');
                formView.classList.remove('hidden');
                if(module === 'audits') renderChecklist();
            } else {
                formView.classList.add('hidden');
                listView.classList.remove('hidden');
            }
        }

        // --- Utils ---
        function getBadgeClass(type) {
            const styles = {
                success: 'bg-emerald-100 text-emerald-800 border-emerald-200',
                warning: 'bg-amber-100 text-amber-800 border-amber-200',
                danger: 'bg-red-100 text-red-800 border-red-200',
                info: 'bg-blue-100 text-blue-800 border-blue-200',
                purple: 'bg-purple-100 text-purple-800 border-purple-200',
            };
            return `px-2.5 py-1 rounded-md text-xs font-bold border ${styles[type] || styles.info} uppercase tracking-wider`;
        }

        // --- Charts Implementation (Chart.js) ---
        function initCharts() {
            // Trend Chart
            const ctxTrend = document.getElementById('trendChart').getContext('2d');
            
            // Create gradient for TRIR area
            const gradientTrir = ctxTrend.createLinearGradient(0, 0, 0, 400);
            gradientTrir.addColorStop(0, 'rgba(99, 102, 241, 0.2)');
            gradientTrir.addColorStop(1, 'rgba(99, 102, 241, 0)');

            new Chart(ctxTrend, {
                type: 'line',
                data: {
                    labels: DASHBOARD_DATA.incidentTrend.map(d => d.month),
                    datasets: [
                        {
                            label: 'TRIR Score', data: DASHBOARD_DATA.incidentTrend.map(d => d.trir),
                            yAxisID: 'y1', type: 'line', fill: true, backgroundColor: gradientTrir,
                            borderColor: '#6366f1', tension: 0.4, pointRadius: 0
                        },
                        {
                            label: 'Near Miss', data: DASHBOARD_DATA.incidentTrend.map(d => d.nearMiss),
                            yAxisID: 'y', borderColor: '#3b82f6', tension: 0.4, borderWidth: 3
                        },
                        {
                            label: 'First Aid', data: DASHBOARD_DATA.incidentTrend.map(d => d.firstAid),
                            yAxisID: 'y', borderColor: '#f59e0b', tension: 0.4, borderWidth: 3
                        },
                        {
                            label: 'LTI', data: DASHBOARD_DATA.incidentTrend.map(d => d.lti),
                            yAxisID: 'y', borderColor: '#ef4444', tension: 0.4, borderWidth: 3
                        }
                    ]
                },
                options: {
                    responsive: true, maintainAspectRatio: false,
                    interaction: { mode: 'index', intersect: false },
                    scales: {
                        x: { grid: { display: false } },
                        y: { type: 'linear', display: true, position: 'left', grid: { borderDash: [3, 3] } },
                        y1: { type: 'linear', display: true, position: 'right', grid: { display: false } }
                    },
                    plugins: { legend: { position: 'top' } }
                }
            });

            // Compliance Chart
            const ctxComp = document.getElementById('complianceChart').getContext('2d');
            new Chart(ctxComp, {
                type: 'doughnut',
                data: {
                    labels: DASHBOARD_DATA.auditCompliance.map(d => d.name),
                    datasets: [{
                        data: DASHBOARD_DATA.auditCompliance.map(d => d.value),
                        backgroundColor: DASHBOARD_DATA.auditCompliance.map(d => d.color),
                        borderWidth: 0,
                        hoverOffset: 4
                    }]
                },
                options: {
                    responsive: true, maintainAspectRatio: false,
                    cutout: '70%',
                    plugins: { legend: { position: 'bottom' } }
                }
            });
        }

        // --- JSA Module ---
        function renderJSAs() {
            const container = document.getElementById('jsa-container');
            if(jsas.length === 0) {
                container.innerHTML = `
                    <div class="col-span-full text-center py-20 bg-white rounded-2xl border border-dashed border-slate-300 shadow-sm">
                        <i data-lucide="layers" class="mx-auto text-slate-300 mb-4 w-14 h-14"></i>
                        <h4 class="text-xl font-bold text-slate-700">No Risk Assessments Found</h4>
                        <p class="text-slate-500 mt-2 max-w-md mx-auto">Proactive safety starts here. Create a JSA before approving high-risk permits.</p>
                    </div>`;
            } else {
                container.innerHTML = jsas.map((jsa, idx) => `
                    <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-200 hover:shadow-md transition-shadow">
                        <div class="flex justify-between items-start mb-4">
                            <div>
                                <span class="${getBadgeClass('purple')}">JSA-${String(idx + 1).padStart(3, '0')}</span>
                                <h4 class="font-bold text-lg text-slate-800 mt-2">${jsa.taskName}</h4>
                            </div>
                            <span class="${getBadgeClass(jsa.residualRisk === 'Low' ? 'success' : 'warning')}">Res. Risk: ${jsa.residualRisk}</span>
                        </div>
                        <p class="text-sm text-slate-600 mb-4"><span class="font-semibold">Location:</span> ${jsa.location} | <span class="font-semibold">Date:</span> ${jsa.date}</p>
                        <div class="bg-slate-50 rounded-xl p-4 border border-slate-100">
                            <h5 class="text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Key Controls Implemented</h5>
                            <ul class="list-disc pl-4 text-sm text-slate-700 space-y-1">
                                ${jsa.controls.split('\n').filter(c => c.trim()).map(c => `<li>${c}</li>`).join('')}
                            </ul>
                        </div>
                    </div>`).join('');
            }
            lucide.createIcons();
        }

        document.getElementById('jsaForm').addEventListener('submit', (e) => {
            e.preventDefault();
            const fd = new FormData(e.target);
            jsas.unshift({
                taskName: fd.get('taskName'), location: fd.get('location'),
                hazards: fd.get('hazards'), controls: fd.get('controls'),
                residualRisk: fd.get('residualRisk'), date: new Date().toLocaleDateString()
            });
            e.target.reset();
            toggleForm('jsa', false);
            renderJSAs();
        });

        // --- Audits Module ---
        function renderChecklist() {
            const type = document.getElementById('auditType').value;
            const items = EXPERT_CHECKLISTS[type];
            currentChecklistStatus = items.map(text => ({ text, status: null }));
            updateChecklistUI();
        }

        function setChecklistStatus(idx, status) {
            currentChecklistStatus[idx].status = status;
            updateChecklistUI();
        }

        function updateChecklistUI() {
            const container = document.getElementById('checklist-container');
            container.innerHTML = currentChecklistStatus.map((item, idx) => {
                const isPass = item.status === 'Pass';
                const isFail = item.status === 'Fail';
                const isNA = item.status === 'N/A';
                
                let bgClass = 'bg-white border-slate-200 hover:border-blue-300 shadow-sm';
                if(isPass) bgClass = 'bg-emerald-50 border-emerald-200';
                if(isFail) bgClass = 'bg-red-50 border-red-200';
                if(isNA) bgClass = 'bg-slate-100 border-slate-300';

                return `
                <div class="flex flex-col md:flex-row md:items-center justify-between p-5 border rounded-xl transition-all ${bgClass}">
                    <p class="text-sm font-semibold pr-4 mb-4 md:mb-0 ${item.status ? 'text-slate-700' : 'text-slate-800'}">${item.text}</p>
                    <div class="flex gap-2 shrink-0 bg-white p-1 rounded-lg border border-slate-200 shadow-sm">
                        <button type="button" onclick="setChecklistStatus(${idx}, 'Pass')" class="px-4 py-2 rounded-md text-sm font-bold flex items-center gap-1.5 transition-all ${isPass ? 'bg-emerald-500 text-white shadow-md' : 'text-slate-500 hover:bg-slate-100'}">
                            <i data-lucide="check-circle" class="w-4 h-4"></i> Pass
                        </button>
                        <button type="button" onclick="setChecklistStatus(${idx}, 'Fail')" class="px-4 py-2 rounded-md text-sm font-bold flex items-center gap-1.5 transition-all ${isFail ? 'bg-red-500 text-white shadow-md' : 'text-slate-500 hover:bg-slate-100'}">
                            <i data-lucide="x-circle" class="w-4 h-4"></i> Fail
                        </button>
                        <button type="button" onclick="setChecklistStatus(${idx}, 'N/A')" class="px-4 py-2 rounded-md text-sm font-bold transition-all ${isNA ? 'bg-slate-500 text-white shadow-md' : 'text-slate-500 hover:bg-slate-100'}">
                            N/A
                        </button>
                    </div>
                </div>`;
            }).join('');
            lucide.createIcons();
        }

        function renderAudits() {
            const container = document.getElementById('audits-container');
            if(audits.length === 0) {
                container.innerHTML = `
                    <div class="text-center py-20 bg-white rounded-2xl border border-dashed border-slate-300 shadow-sm">
                        <i data-lucide="clipboard-list" class="mx-auto text-slate-300 mb-4 w-14 h-14"></i>
                        <h4 class="text-xl font-bold text-slate-700">No Audits Conducted Yet</h4>
                        <p class="text-slate-500 mt-2">Start your proactive safety program by creating your first audit.</p>
                    </div>`;
            } else {
                const rows = audits.map((audit) => {
                    const passClass = audit.score >= 80 ? 'bg-emerald-100 text-emerald-800' : 'bg-amber-100 text-amber-800';
                    const barClass = audit.score >= 80 ? 'bg-emerald-500' : 'bg-amber-500';
                    return `
                    <tr class="border-b border-slate-100 hover:bg-slate-50 transition-colors">
                        <td class="p-5 font-bold text-slate-800">${audit.type}</td>
                        <td class="p-5 text-slate-600 font-medium">${audit.location}</td>
                        <td class="p-5 text-slate-500">${audit.date}</td>
                        <td class="p-5">
                            <div class="flex items-center gap-3">
                                <span class="px-2.5 py-1 rounded-md font-bold ${passClass}">${audit.score}%</span>
                                <div class="w-24 h-2 bg-slate-200 rounded-full overflow-hidden hidden md:block">
                                    <div class="h-full ${barClass}" style="width: ${audit.score}%"></div>
                                </div>
                            </div>
                        </td>
                        <td class="p-5"><span class="${getBadgeClass('info')}">Completed</span></td>
                    </tr>`;
                }).join('');

                container.innerHTML = `
                    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
                        <table class="w-full text-left border-collapse">
                            <thead>
                                <tr class="bg-slate-50 border-b border-slate-200 text-xs text-slate-500 uppercase tracking-wider">
                                    <th class="p-5 font-bold">Audit Type</th>
                                    <th class="p-5 font-bold">Location</th>
                                    <th class="p-5 font-bold">Date</th>
                                    <th class="p-5 font-bold">Score</th>
                                    <th class="p-5 font-bold">Status</th>
                                </tr>
                            </thead>
                            <tbody class="text-sm">${rows}</tbody>
                        </table>
                    </div>`;
            }
            lucide.createIcons();
        }

        document.getElementById('auditForm').addEventListener('submit', (e) => {
            e.preventDefault();
            const answered = currentChecklistStatus.filter(c => c.status !== null);
            const passed = answered.filter(c => c.status === 'Pass').length;
            const score = answered.length > 0 ? Math.round((passed / answered.length) * 100) : 0;
            
            const fd = new FormData(e.target);
            audits.unshift({
                type: fd.get('type'), location: fd.get('location'),
                date: new Date().toLocaleDateString(), score, checklist: [...currentChecklistStatus]
            });
            e.target.reset();
            toggleForm('audits', false);
            renderAudits();
        });

        // --- Incidents Module ---
        function toggleRootCause() {
            const category = document.getElementById('incidentCategory').value;
            const isSevere = category.includes('LTI') || category.includes('Medical');
            const rcSection = document.getElementById('rootCauseSection');
            if(isSevere) {
                rcSection.classList.remove('hidden');
                rcSection.querySelector('textarea').setAttribute('required', 'true');
            } else {
                rcSection.classList.add('hidden');
                rcSection.querySelector('textarea').removeAttribute('required');
            }
        }

        function renderIncidents() {
            const container = document.getElementById('incidents-container');
            if(incidents.length === 0) {
                container.innerHTML = `
                    <div class="col-span-full text-center py-20 bg-white rounded-2xl border border-dashed border-slate-300 shadow-sm">
                        <i data-lucide="shield-check" class="mx-auto text-emerald-400 mb-4 w-14 h-14"></i>
                        <h4 class="text-xl font-bold text-slate-700">Zero Incidents Reported</h4>
                        <p class="text-slate-500 mt-2">Excellent. Maintain vigilance and proactive reporting to keep the site safe.</p>
                    </div>`;
            } else {
                container.innerHTML = incidents.map((inc) => {
                    const badgeType = inc.category.includes('LTI') ? 'danger' : 'warning';
                    return `
                    <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-200 border-l-4 border-l-red-500 relative hover:shadow-md transition-shadow">
                        <div class="absolute top-6 right-6">
                            <span class="${getBadgeClass(badgeType)}">${inc.category}</span>
                        </div>
                        <h4 class="font-bold text-lg text-slate-800 pr-24 mb-1">${inc.title}</h4>
                        <p class="text-sm text-slate-500 mb-4 font-medium flex items-center gap-2">
                            ${inc.date} <span class="w-1 h-1 rounded-full bg-slate-300"></span> ${inc.location}
                        </p>
                        <div class="space-y-4">
                            <div>
                                <p class="text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">Description</p>
                                <p class="text-sm text-slate-700 leading-relaxed bg-slate-50 p-3 rounded-lg border border-slate-100">${inc.description}</p>
                            </div>
                            ${inc.rootCause ? `
                            <div>
                                <p class="text-xs font-bold text-red-500 uppercase tracking-wider mb-1 flex items-center gap-1"><i data-lucide="file-search" class="w-3 h-3"></i> Identified Root Cause</p>
                                <p class="text-sm text-red-900 leading-relaxed bg-red-50 p-3 rounded-lg border border-red-100">${inc.rootCause}</p>
                            </div>` : ''}
                            <div>
                                <p class="text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">Immediate Action</p>
                                <p class="text-sm text-slate-700 leading-relaxed border-l-2 border-slate-300 pl-3">${inc.action}</p>
                            </div>
                        </div>
                    </div>`;
                }).join('');
            }
            lucide.createIcons();
        }

        document.getElementById('incidentForm').addEventListener('submit', (e) => {
            e.preventDefault();
            const fd = new FormData(e.target);
            incidents.unshift({
                title: fd.get('title'), category: fd.get('category'), location: fd.get('location'),
                description: fd.get('description'), action: fd.get('action'), rootCause: fd.get('rootCause') || '',
                date: new Date().toLocaleString()
            });
            e.target.reset();
            toggleRootCause();
            toggleForm('incidents', false);
            renderIncidents();
        });

        // --- PTW Module ---
        function renderPermits() {
            const container = document.getElementById('ptw-container');
            const dashCount = document.getElementById('dash-permit-count');
            dashCount.innerText = permits.length;

            if(permits.length === 0) {
                container.innerHTML = `
                    <div class="col-span-full text-center py-20 bg-white rounded-2xl border border-dashed border-slate-300 shadow-sm">
                        <i data-lucide="file-signature" class="mx-auto text-slate-300 mb-4 w-14 h-14"></i>
                        <h4 class="text-xl font-bold text-slate-700">No Active Permits</h4>
                        <p class="text-slate-500 mt-2">All high-risk operations are currently suspended or not required.</p>
                    </div>`;
            } else {
                container.innerHTML = permits.map((p) => {
                    const badgeType = p.type.includes('Hot') ? 'danger' : (p.type.includes('Confined') ? 'purple' : 'info');
                    return `
                    <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-200 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 hover:shadow-md transition-shadow">
                        <div class="flex-1">
                            <span class="${getBadgeClass(badgeType)}">${p.type}</span>
                            <h4 class="font-bold text-lg text-slate-800 mt-3">${p.task}</h4>
                            <p class="text-sm font-medium text-slate-500 mt-1">Loc: ${p.location}</p>
                        </div>
                        <div class="bg-slate-50 p-4 rounded-xl border border-slate-100 flex flex-col items-end min-w-[160px]">
                            <span class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-1">Status</span>
                            <span class="inline-flex items-center gap-1.5 text-emerald-600 font-bold text-sm bg-emerald-100 px-3 py-1 rounded-md border border-emerald-200 shadow-sm">
                                <i data-lucide="check-circle" class="w-3.5 h-3.5"></i> ACTIVE
                            </span>
                            <p class="text-xs font-medium text-slate-500 mt-2 text-right">Valid Until:<br/><span class="text-slate-800 font-bold">${p.validUntil}</span></p>
                        </div>
                    </div>`;
                }).join('');
            }
            lucide.createIcons();
        }

        document.getElementById('ptwForm').addEventListener('submit', (e) => {
            e.preventDefault();
            const fd = new FormData(e.target);
            permits.unshift({
                type: fd.get('type'), task: fd.get('task'), location: fd.get('location'), validUntil: 'Today 18:00'
            });
            e.target.reset();
            toggleForm('ptw', false);
            renderPermits();
        });

        // --- Chatbot Module ---
        function toggleChat() {
            isChatOpen = !isChatOpen;
            const fab = document.getElementById('chat-fab');
            const win = document.getElementById('chat-window');
            const botIcon = document.getElementById('chat-icon-bot');
            const closeIcon = document.getElementById('chat-icon-close');

            if(isChatOpen) {
                fab.classList.remove('bg-gradient-to-r', 'from-indigo-600', 'to-blue-600');
                fab.classList.add('bg-slate-800');
                botIcon.classList.add('hidden');
                closeIcon.classList.remove('hidden');
                win.classList.remove('hidden');
                scrollToBottom();
            } else {
                fab.classList.add('bg-gradient-to-r', 'from-indigo-600', 'to-blue-600');
                fab.classList.remove('bg-slate-800');
                botIcon.classList.remove('hidden');
                closeIcon.classList.add('hidden');
                win.classList.add('hidden');
            }
        }

        function scrollToBottom() {
            const container = document.getElementById('chat-messages');
            container.scrollTop = container.scrollHeight;
        }

        function renderMessages() {
            const container = document.getElementById('chat-messages');
            container.innerHTML = chatMessages.map(msg => {
                const isAI = msg.role === 'ai';
                return `
                <div class="flex ${isAI ? 'justify-start' : 'justify-end'}">
                    ${isAI ? `<div class="w-8 h-8 rounded-full bg-indigo-100 flex items-center justify-center mr-2 shrink-0"><i data-lucide="bot" class="w-4 h-4 text-indigo-600"></i></div>` : ''}
                    <div class="max-w-[80%] p-4 rounded-2xl text-sm leading-relaxed ${isAI ? 'bg-white border border-slate-200 text-slate-800 rounded-tl-sm shadow-sm' : 'bg-indigo-600 text-white rounded-tr-sm shadow-md'}">
                        ${msg.text.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>').replace(/\n/g, '<br/>')}
                    </div>
                </div>`;
            }).join('');
            lucide.createIcons();
            scrollToBottom();
        }

        async function handleChatSubmit(e) {
            e.preventDefault();
            const inputEl = document.getElementById('chatInput');
            const btnEl = document.getElementById('chatSubmitBtn');
            const indicator = document.getElementById('typing-indicator');
            const text = inputEl.value.trim();
            if(!text || isTyping) return;

            // User msg
            chatMessages.push({ role: 'user', text });
            inputEl.value = '';
            renderMessages();

            // Setup loading state
            isTyping = true;
            inputEl.disabled = true;
            btnEl.disabled = true;
            indicator.classList.remove('hidden');
            scrollToBottom();

            try {
                const apiKey = ""; // Implicitly uses Canvas credentials
                const apiUrl = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`;
                
                const payload = {
                    contents: chatMessages.map(m => ({
                        role: m.role === 'ai' ? 'model' : 'user',
                        parts: [{ text: m.text }]
                    })),
                    systemInstruction: {
                        parts: [{ text: "You are an elite, highly experienced Occupational Health and Safety (HSE) Director with 15 years of field and corporate experience. You specialize in OSHA, NEBOSH, and Saudi Arabian labor laws and construction standards. Provide pragmatic, actionable, and legally sound advice. Structure your answers clearly with bullet points where necessary. Be professional, authoritative, and helpful to the safety officer asking you questions." }]
                    }
                };

                const response = await fetch(apiUrl, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                const data = await response.json();
                
                if (data.candidates && data.candidates[0].content.parts[0].text) {
                    chatMessages.push({ role: 'ai', text: data.candidates[0].content.parts[0].text });
                } else {
                    throw new Error("Invalid response format");
                }
            } catch (error) {
                console.error("AI Error:", error);
                chatMessages.push({ role: 'ai', text: "⚠️ Secure connection to Intelligence Server failed. Please check your network or try again." });
            } finally {
                isTyping = false;
                inputEl.disabled = false;
                btnEl.disabled = false;
                indicator.classList.add('hidden');
                renderMessages();
                inputEl.focus();
            }
        }
    </script>
</body>
</html>
